---
import SiteLayout from "../layouts/SiteLayout.astro";

const pillars = [
  {
    title: "One repo, clear surfaces",
    body: "Keep product code, API code, marketing content, and documentation in predictable top-level folders.",
  },
  {
    title: "Docs are first-class",
    body: "Use /docs for product, technical, operational, and agentic context instead of scattering notes through source folders.",
  },
  {
    title: "Deploy without tangling concerns",
    body: "Use /tooling for shared automation while keeping platform entrypoints where each provider expects them.",
  },
];
---

<SiteLayout
  title="gg marketing"
  description="SEO-friendly starter surface for the gg monorepo template."
>
  <main class="page-shell">
    <section class="hero">
      <p class="eyebrow">gg starter</p>
      <h1>Ship product, content, and infrastructure from one clean repo.</h1>
      <p class="lede">
        This starter is designed for teams that need a flagship application, a
        service layer, and a marketing site without collapsing everything into a
        single framework.
      </p>
    </section>

    <section class="pillars">
      {
        pillars.map((pillar) => (
          <article class="pillar">
            <h2>{pillar.title}</h2>
            <p>{pillar.body}</p>
          </article>
        ))
      }
    </section>
  </main>
</SiteLayout>
